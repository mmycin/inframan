# Maintainer: Mycin <https://github.com/mmycin/inframan>
pkgname=inframan
pkgver=0.1.0
pkgrel=1
pkgdesc="Infrastructure Manager CLI"
arch=('x86_64')
url="https://github.com/mmycin/inframan"
license=('MIT')
depends=('glibc')
makedepends=('cmake')
source=("https://github.com/mmycin/inframan/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('REPLACE_WITH_SHA256')

build() {
  cmake -B build -S "$pkgname-$pkgver" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
